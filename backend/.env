# Archivo .env (no subir a git, agregar a .gitignore)

# URL de conexión a GCP Cloud SQL PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/base_de_datos
# Para GCP Cloud SQL, el host es la IP pública o privada, o usar /cloudsql/project:region:instance con proxy

DATABASE_URL=postgresql://autolavado_user:jH({=975r.A9XXHU@34.27.78.2:5432/autolavado_db

# Si usas Cloud SQL Auth proxy:
# DATABASE_URL=postgresql://autolavado_user:Aa123456*@localhost:5432/autolavado_db

# Para obtener las credenciales:
# 1. Ve a GCP Console > SQL > Tu instancia > Conexiones
# 2. Crea un usuario y contraseña
# 3. Para desarrollo, instala Cloud SQL Auth proxy y ejecuta:
#    cloud_sql_proxy -instances=tu_proyecto:tu_region:tu_instancia=tcp:5432
# 4. Para producción, configura la IP de Azure App Service en las autorizaciones de red de GCP SQL.